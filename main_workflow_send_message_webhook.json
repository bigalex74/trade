      {
        "parameters": {
          "jsCode": "const notifyResult = $('Notify Telegram').first().json;\nconst jobData = $('Webhook Trigger').first().json;\nreturn { job_id: jobData.job_id, message_type: jobData.message, notify_status: notifyResult.success ? 'sent' : 'error', message_id: notifyResult.message_id, logged_at: new Date().toISOString() };"
        },
