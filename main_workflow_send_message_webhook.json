[
  {
    "id": "main_send_message",
    "name": "Send Message",
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "send-message",
          "responseMode": "lastNode",
          "options": {}
        },
        "id": "webhook_trigger",
        "name": "Webhook Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2,
        "position": [100, 300],
        "webhookId": "send-message-trigger"
      },
      {
        "parameters": {
          "jsCode": "const VALID_MESSAGES = ['create_job', 'start_processing', 'processing', 'error_processing', 'finish_processing', 'stop_processing'];\nconst payload = $('Webhook Trigger').first().json;\nif (!payload || !payload.message) throw new Error('Missing payload.message');\nif (!VALID_MESSAGES.includes(payload.message)) throw new Error(`Invalid message type: ${payload.message}`);\nif (!payload.job_id) throw new Error('Missing job_id in payload');\nconst messageMap = { 'create_job': 'create', 'start_processing': 'start', 'processing': 'process', 'error_processing': 'error', 'finish_processing': 'finish', 'stop_processing': 'stop' };\nreturn { valid: true, job_id: payload.job_id, message_type: payload.message, notify_type: messageMap[payload.message] };"
        },
        "id": "validate_payload",
        "name": "Validate Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [350, 300]
      },
      {
        "parameters": {
          "workflowId": "3fbb84cf-8a84-4ac2-8b33-936ceaa07a0a",
          "options": {
            "waitForSubWorkflow": true
          }
        },
        "id": "get_context",
        "name": "Get Context",
        "type": "n8n-nodes-base.executeWorkflow",
        "typeVersion": 1,
        "position": [600, 300]
      },
      {
        "parameters": {
          "rules": {
            "values": [
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.notify_type }}", "rightValue": "create", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "create" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.notify_type }}", "rightValue": "start", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "start" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.notify_type }}", "rightValue": "process", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "process" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.notify_type }}", "rightValue": "error", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "error" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.notify_type }}", "rightValue": "finish", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "finish" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.notify_type }}", "rightValue": "stop", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "stop" }
            ]
          }
        },
