      {
        "parameters": {
          "jsCode": "const RUBLE_EXCHANGE_RATE = 79;\n\nconst billing_polza = Number($('Данные document_jobs').first().json.billing_polza) - Number($('Billing Polza.ai').first().json.amount);\nconst billing_neuro = -(Number($('Данные document_jobs').first().json.billing_neuro) - Number($('Billing Neuro').first().json.total_usage)) / 100;\n\nconst startedAtMs = DateTime.fromISO($('Данные document_jobs').first().json.created_at);\nconst diff = startedAtMs.diffNow().negate().toFormat(\"hh':'mm':'ss\")\n\nconst done = Number($('Количество законченных чанков').first().json.chunks_done);\nconst total = Number($('Общее количество чанков').first().json.chunks_total);\n// const done = Math.floor(Math.random() * total);\nconst ratio = Math.min(1, Math.max(0, done / total));\n\nconst startedAt = startedAtMs.toFormat(\"dd.MM.yyyy HH:mm:ss\");\n\nconst width =20;\nconst filled = Math.round(ratio * width);\nconst bar = '█'.repeat(filled) + '░'.repeat(width - filled);\n\nreturn {\n  message: `\n🔄 <b>Перевод в процессе</b>\n\n📄 Документ: ${$('Данные document_jobs').first().json.file_name}\n<b>🗓 Старт:</b> <code>${ startedAt }</code> \n<b>⏱ Прошло: <code>${ diff }</code></b>\n<b>📊 Прогресс:</b> <code>${ `${bar} ${Math.floor(ratio*100)}%` }</code> \n<b>🧩 Текущий чанк: <code>${ done }/${ total }</code></b>\n💰 Потрачено на Polza.ai: \n      ₽ ${ billing_polza.toFixed(2) }\n💰 Потрачено на NeuroAPI: \n      ₽ ${(billing_neuro * RUBLE_EXCHANGE_RATE).toFixed(2).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \" \")}\n\n<i>Сообщение сгенерировано автоматически.</i>\n  `,\n  type: 'edit',\n  button: {}\n} "
        },
