[
  {
    "name": "Send Message - Format",
    "nodes": [
      {
        "parameters": {},
        "id": "trigger",
        "name": "When Executed by Another Workflow",
        "type": "n8n-nodes-base.executeWorkflowTrigger",
        "typeVersion": 1,
        "position": [-200, 300]
      },
      {
        "parameters": {
          "rules": {
            "values": [
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.template }}", "rightValue": "create_job", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "CREATE JOB" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.template }}", "rightValue": "start_processing", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "START_PROCESSING" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.template }}", "rightValue": "processing", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "PROCESSING" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.template }}", "rightValue": "error_processing", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "ERROR_PROCESSING" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.template }}", "rightValue": "finish_processing", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "FINISH_PROCESSING" },
              { "conditions": { "conditions": [{ "leftValue": "={{ $json.template }}", "rightValue": "stop_processing", "operator": { "type": "string", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "STOP_PROCESSING" }
            ]
          }
        },
        "id": "node_router",
        "name": "Switch Template",
        "type": "n8n-nodes-base.switch",
        "typeVersion": 3,
        "position": [100, 300]
      },
      {
        "parameters": {
          "jsCode": "return {
  message: `
▶️ <b>Обработка началась</b>

📄 Документ: <b>${ $json.file_name }</b>
🔄 Статус: <b>В процессе</b>
`,
  type: 'start',
  button: {}
};"
        },
        "id": "code_start",
        "name": "Сообщение Старт обработки",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [400, -50]
      },
      {
        "parameters": {
          "jsCode": "const RUBLE_EXCHANGE_RATE = 79;
const billing_polza = Number($json.billing_polza) - Number($json.amount);
const billing_neuro = -(Number($json.billing_neuro) - Number($json.total_usage)) / 100;
const diff = DateTime.fromISO($json.created_at).diff(DateTime.fromISO($json.finished_at)).negate().toFormat("hh':'mm':'ss");

return {
  message: `
🔄 <b>Перевод в процессе</b>

📄 Документ: ${$json.file_name}
💰 Потрачено на Polza.ai: ₽ ${ billing_polza.toFixed(2) }
💰 Потрачено на NeuroAPI: ₽ ${(billing_neuro * RUBLE_EXCHANGE_RATE).toFixed(2).toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ")}
  `,
  type: 'edit',
  button: {}
} "
        },
        "id": "code_process",
        "name": "Сообщение Перевод в процессе",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [400, 100]
      },
      {
        "parameters": {
          "jsCode": "const RUBLE_EXCHANGE_RATE = 79;
const billing_polza = Number($json.billing_polza) - Number($json.amount);
const billing_neuro = -(Number($json.billing_neuro) - Number($json.total_usage)) / 100;
const diff = DateTime.fromISO($json.created_at).diff(DateTime.fromISO($json.finished_at)).negate().toFormat("hh':'mm':'ss");

return {
  message: `
✅ <b>Перевод завершен!</b>

📄 Документ (исходный): ${$json.file_name}
📄 Документ (с переводом): ${$json.translated_file}

💰 Итоговая стоимость Polza.ai: ₽ ${ billing_polza.toFixed(2) }
💰 Итоговая стоимость NeuroAPI: ₽ ${(billing_neuro * RUBLE_EXCHANGE_RATE).toFixed(2).toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ")}

⏱ Переведено за: <code>${ diff } (чч:мм:сс)</code>
  `,
  type: 'finish',
  button: {}
};"
        },
        "id": "code_finish",
        "name": "Сообщение Перевод завершен",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [400, 250]
      },
      {
        "parameters": {
          "jsCode": "return {
  message: `
⚠️ <b>Ошибка обработки</b>

📄 Документ: ${$json.file_name}

❌ <b>Ошибка:</b> 
${$json.error_text}

🔁 Повторная попытка через 30 секунд...
  `,
  type: 'error',
  button: {}
} "
        },
        "id": "code_error",
        "name": "Сообщение Ошибка в процессе",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [400, 400]
      },
      {
        "parameters": {
          "jsCode": "return {
  message: `
🚨 <b>Перевод остановлен</b>

📄 Документ: ${$json.file_name}

⛔ Обработка приостановлена.
      Для повтора нажми на кнопку )

`,
  type: 'stop',
  button: {
    name: '🔁 Повторить',
    callbackData: 'repeat_translate',
  }
} "
        },
        "id": "code_stop",
        "name": "Сообщение Перевод остановлен",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [400, 550]
      },
      {
        "parameters": {
          "jsCode": "return {
  message: `
🆕 <b>Задача создана</b>
  
📄  Документ: <b>${ $json.file_name }</b>

🚀 <i>Обработка начнётся через несколько секунд...</i>`,
  type: 'create',
  button: {}
}"
        },
        "id": "code_create",
        "name": "Сообщение Задача создана",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [400, -200]
      },
      {
        "parameters": { "numberInputs": 6 },
        "id": "merge_output",
        "name": "Merge Output",
        "type": "n8n-nodes-base.merge",
